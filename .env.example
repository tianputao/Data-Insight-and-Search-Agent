# ─── Azure OpenAI Configuration ───────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
# Authentication mode: auto | key | aad
#   key  → use AZURE_OPENAI_API_KEY (requires key-based auth enabled on resource)
#   aad  → use DefaultAzureCredential (Entra ID / Managed Identity; no key needed)
#   auto → use key if AZURE_OPENAI_API_KEY is set, otherwise fall back to aad
AZURE_OPENAI_AUTH_MODE=auto
AZURE_OPENAI_API_KEY=your-openai-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

# ─── Azure AI Search Configuration ────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key-here
AZURE_SEARCH_INDEX_NAME=your-index-name

# ─── Azure AI Search Index Field Names ────────────────────────────────────────
# Override only fields that differ from the defaults shown below.

# Core fields
AZURE_SEARCH_ID_FIELD=id
AZURE_SEARCH_SESSION_ID_FIELD=session_id
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_TITLE_FIELD=title
AZURE_SEARCH_FILEPATH_FIELD=filepath
AZURE_SEARCH_URL_FIELD=url
AZURE_SEARCH_METADATA_FIELD=metadata
AZURE_SEARCH_DOC_METADATA_FIELD=doc_metadata
AZURE_SEARCH_DESCRIPTION_FIELD=description

# Vector fields (dimensions must match embedding model — 3072 for text-embedding-3-large)
AZURE_SEARCH_VECTOR_FIELD=contentVector
AZURE_SEARCH_METADATA_VECTOR_FIELD=full_metadata_vector
AZURE_SEARCH_VECTOR_DIMENSIONS=3072

# Document metadata fields
AZURE_SEARCH_MAIN_TITLE_FIELD=main_title
AZURE_SEARCH_SUB_TITLE_FIELD=sub_title
AZURE_SEARCH_PUBLISHER_FIELD=publisher
AZURE_SEARCH_DOCUMENT_CODE_FIELD=document_code
AZURE_SEARCH_DOCUMENT_CATEGORY_FIELD=document_category
AZURE_SEARCH_DOCUMENT_SCHEMA_FIELD=document_schema

# Language fields
AZURE_SEARCH_PRIMARY_LANGUAGE_FIELD=primary_language
AZURE_SEARCH_SECONDARY_LANGUAGE_FIELD=secondary_language
AZURE_SEARCH_MAIN_TITLE_SEC_LANGUAGE_FIELD=main_title_sec_language
AZURE_SEARCH_SUB_TITLE_SEC_LANGUAGE_FIELD=sub_title_sec_language

# Header hierarchy fields
AZURE_SEARCH_FULL_HEADERS_FIELD=full_headers
AZURE_SEARCH_H1_FIELD=h1
AZURE_SEARCH_H2_FIELD=h2
AZURE_SEARCH_H3_FIELD=h3
AZURE_SEARCH_H4_FIELD=h4
AZURE_SEARCH_H5_FIELD=h5
AZURE_SEARCH_H6_FIELD=h6

# Timestamp fields
AZURE_SEARCH_TIMESTAMP_FIELD=timestamp
AZURE_SEARCH_PUBLISH_DATE_FIELD=publish_date

# Other fields
AZURE_SEARCH_IMAGE_MAPPING_FIELD=image_mapping

# Search configuration
AZURE_SEARCH_SEMANTIC_CONFIG=default
AZURE_SEARCH_VECTOR_PROFILE=vectorSearchProfile

# ─── Azure Blob Storage — Document Citation URLs ───────────────────────────────
# Base URL of the blob container where indexed documents are stored.
# Appended with the document filepath to construct citation links.
BASE_URL=https://youraccount.blob.core.windows.net/your-doc-container
# SAS token granting read+list access to the document container.
SAS_TOKEN=your-sas-signature-here

# ─── Azure Blob Storage — Image URLs (optional) ───────────────────────────────
# Base URL of the container holding inline document images.
AZURE_IMAGE_BASE_URL=https://youraccount.blob.core.windows.net/your-image-container
# SAS token granting read access to the image container.
AZURE_IMAGE_SAS_TOKEN=your-sas-signature-here

# ─── Azure AI Foundry Configuration (optional — for monitoring & evaluation) ───
AZURE_AI_PROJECT_CONNECTION_STRING=https://your-foundry-resource.services.ai.azure.com/api/projects/YourProject

# ─── Application Configuration ────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=20
DEFAULT_TOP_K=5

# ─── Feature Flags ─────────────────────────────────────────────────────────────
DEFAULT_ENABLE_SEMANTIC_RERANKER=true
DEFAULT_ENABLE_AGENTIC_RETRIEVAL=true

# ─── Azure Databricks Configuration (optional — for DataInsight & Metadata agents)
# When all three required fields (HOST, TOKEN, HTTP_PATH) are set,
# DatabricksConfig.is_configured() returns True and both Databricks agents are enabled.

# Workspace URL (e.g. https://adb-1234567890123456.18.azuredatabricks.net)
DATABRICKS_HOST=https://adb-0000000000000000.00.azuredatabricks.net/
# Personal Access Token (PAT) — use short-lived tokens or OAuth M2M in production
DATABRICKS_TOKEN=dapiYourDatabricksPersonalAccessTokenHere
# HTTP path copied from the SQL Warehouse connection details page
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
# Unity Catalog name
DATABRICKS_CATALOG=your_catalog_name
# Comma-separated list of schemas to expose to agents (first = default)
DATABRICKS_SCHEMAS=silver,gold

